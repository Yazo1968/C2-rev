# Copy to .env.local before `npm run dev`. None of these are secrets, but they
# come from Firebase project settings + the deployed c2-api Cloud Run URL.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=c2-intelligence
VITE_FIREBASE_APP_ID=

# c2-api Cloud Run URL — printed by api/deploy.sh
VITE_API_BASE_URL=
